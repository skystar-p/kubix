{
  "apiVersion": "cert-manager.io/v1",
  "kind": "Certificate",
  "metadata": {
    "name": "example-com-tls",
    "namespace": "default"
  },
  "spec": {
    "dnsNames": [
      "example.com"
    ],
    "issuerRef": {
      "kind": "ClusterIssuer",
      "name": "letsencrypt-prod"
    },
    "secretName": "example-com-tls"
  }
}
